<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1">
   <stylesheets>
      <URL value="@styles/mainStyle.css" />
   </stylesheets>
   <left>
      <VBox spacing="15.0" BorderPane.alignment="CENTER">
         <children>
            <VBox id="media" spacing="10.0">
               <children>
                  <Button fx:id="btnSongs" mnemonicParsing="false" text="Songs" />
                  <Button fx:id="btnBooks" mnemonicParsing="false" text="Books" />
                  <Button fx:id="btnPodcasts" mnemonicParsing="false" text="Podcasts" />
                  <Button fx:id="btnArtists" mnemonicParsing="false" text="Artists" />
                  <Button fx:id="btnAlbum" mnemonicParsing="false" text="Album" />
                  <Button fx:id="btnGenres" mnemonicParsing="false" text="Genres" />
                  <Button fx:id="btnPlaylist" mnemonicParsing="false" text="Playlist" />
               </children>
               <padding>
                  <Insets top="5.0" />
               </padding>
            </VBox>
            <VBox id="utils" spacing="10.0">
               <children>
                  <Button fx:id="btnLocalMedia" mnemonicParsing="false" text="Local media" />
                  <Button fx:id="btnSettings" mnemonicParsing="false" text="Settings" />
                  <Button fx:id="btnFolders" mnemonicParsing="false" text="Folders" />
                  <Button fx:id="btnStats" mnemonicParsing="false" text="Stats" />
               </children>
               <padding>
                  <Insets top="5.0" />
               </padding>
            </VBox>
         </children>
         <padding>
            <Insets top="10.0" />
         </padding>
      </VBox>
   </left>
   <center>
      <AnchorPane fx:id="contentArea" BorderPane.alignment="CENTER" />
   </center>
   <bottom>
      <VBox alignment="CENTER" spacing="8.0" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="currentTrack" alignment="CENTER" prefHeight="16.0" prefWidth="168.0" text="Label" />

            <Slider fx:id="trackSlider" maxWidth="1.7976931348623157E308" />
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="10.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Button fx:id="btnSpeed" text="⚡" />
                        <Button fx:id="btnEqualizer" text="🎚" />
                     </children>
                  </HBox>

                  <HBox alignment="CENTER" spacing="10.0">
                     <children>
                        <Button text="⏪ -10s" />
                        <Button fx:id="btnPrev" text="⏮" />
                        <Button fx:id="btnPlay" text="▶" />
                        <Button fx:id="btnNext" text="⏭" />
                        <Button text="+10s ⏩" />
                     </children>
                     <padding>
                        <Insets top="5.0" />
                     </padding>
                  </HBox>

                  <HBox alignment="CENTER_RIGHT" spacing="10.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Button fx:id="btnFavorite" text="❤" />
                        <Slider fx:id="volumeSlider" prefWidth="100.0" />
                     </children>
                     <padding>
                        <Insets top="5.0" />
                     </padding>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" />
               </padding>
            </HBox>
         </children>
         <padding>
            <Insets top="10.0" />
         </padding>
      </VBox>
   </bottom>
</BorderPane>
