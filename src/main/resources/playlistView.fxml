<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.controllers.PlaylistViewController">
   <stylesheets>
      <URL value="@styles/mainStyle.css" />
   </stylesheets>

   <children>
      <VBox spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
      
            <HBox spacing="10.0">
               <children>
                  <TextField fx:id="searchBar" promptText="Search" HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnSort" text="Sort" />
                  <Button fx:id="btnAdd" text="+" />
               </children>
               <padding>
                  <Insets top="10.0" />
               </padding>
            </HBox>
            <HBox spacing="10.0">
               <children>
                  <Button mnemonicParsing="false" text="Favorites" />
                  <Button mnemonicParsing="false" text="Recently added" />
                  <Button mnemonicParsing="false" text="Most played" />
                  <Button mnemonicParsing="false" text="Recently played" />
               </children>
               <padding>
                  <Insets top="5.0" />
               </padding>
            </HBox>
      
            <ListView fx:id="listView" VBox.vgrow="ALWAYS">
               <padding>
                  <Insets top="5.0" />
               </padding>
            </ListView>
         </children>
      </VBox>

   </children>
</AnchorPane>
