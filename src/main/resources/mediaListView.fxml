<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.controllers.MediaListViewController">
   <stylesheets>
      <URL value="@styles/mainStyle.css" />
   </stylesheets>
   <children>
      <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <HBox spacing="10.0">
               <children>
                  <Button fx:id="btnListPlay" text="▶" />
                  <TextField fx:id="searchBar" promptText="Search" HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnAddDirectory" mnemonicParsing="false" text="+" />
                  <MenuButton fx:id="btnSort" mnemonicParsing="false" text="sort by">
                       <items>
                          <MenuItem text="Title" onAction="#sortByTitle"/>
                          <MenuItem text="File Name" onAction="#sortByFileName"/>
                          <MenuItem text="Artists" onAction="#sortByArtists"/>
                          <MenuItem text="Duration" onAction="#sortByDuration"/>
                          <MenuItem text="Year" onAction="#sortByYear"/>
                          <MenuItem text="Date Added" onAction="#sortByDateAdded"/>
                          <MenuItem text="Date Modified" onAction="#sortByDateModified"/>
                       </items>
                  </MenuButton>
                  <Button fx:id="btnRefresh" text="Refresh" />
               </children>
               <padding>
                  <Insets bottom="5.0" top="10.0" />
               </padding>
            </HBox>

            <ListView fx:id="listView" VBox.vgrow="ALWAYS">
               <padding>
                  <Insets top="5.0" />
               </padding>
            </ListView>
         </children>
      </VBox>
   </children>
</AnchorPane>
