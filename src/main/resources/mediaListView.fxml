<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mokaAlpha.controllers.MediaListViewController">
   <stylesheets>
      <URL value="@styles/mainStyle.css" />
   </stylesheets>
   <children>
      <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <HBox spacing="10.0">
               <children>
                  <Button fx:id="btnListPlay" text="▶" />
                  <TextField fx:id="searchBar" promptText="Search" HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnAddDirectory" mnemonicParsing="false" text="+" />
                  <Button fx:id="btnSort" text="Sort by" />
                  <Button fx:id="btnRefresh" text="Refresh" />
               </children>
               <padding>
                  <Insets bottom="5.0" top="10.0" />
               </padding>
            </HBox>

            <ListView fx:id="listView" VBox.vgrow="ALWAYS">
               <padding>
                  <Insets top="5.0" />
               </padding>
            </ListView>
         </children>
      </VBox>
   </children>
</AnchorPane>
