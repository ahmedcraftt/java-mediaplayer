<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.controllers.MediaListViewController">
   <stylesheets>
      <URL value="@styles/mainStyle.css" />
   </stylesheets>
   <VBox spacing="5.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
      <HBox spacing="10.0">
         <padding>
            <Insets bottom="5.0" top="10.0" />
         </padding>
         <Button fx:id="btnListPlay" text="▶" />
         <TextField fx:id="searchBar" promptText="Search" HBox.hgrow="ALWAYS" />
         <Button fx:id="btnAddDirectory" mnemonicParsing="false" text="+" />
         <MenuButton fx:id="btnSort" mnemonicParsing="false" text="sort by">
            <items>
               <MenuItem onAction="#sortByTitle" text="Title" />
               <MenuItem onAction="#sortByFileName" text="File Name" />
               <MenuItem onAction="#sortByArtists" text="Artists" />
               <MenuItem onAction="#sortByDuration" text="Duration" />
               <MenuItem onAction="#sortByYear" text="Year" />
               <MenuItem onAction="#sortByDateAdded" text="Date Added" />
               <MenuItem onAction="#sortByDateModified" text="Date Modified" />
            </items>
         </MenuButton>
         <Button fx:id="btnRefresh" text="Refresh" />
      </HBox>

      <ListView fx:id="contentList" VBox.vgrow="ALWAYS">
         <padding>
            <Insets top="5.0" />
         </padding>
      </ListView>
      
      <VBox fx:id="metadataPanel" spacing="6.0" styleClass="metadata-panel">
         <Label styleClass="section-title" text="Track Details" />

         <Label fx:id="lblTitle" />
         <Label fx:id="lblArtist" />
         <Label fx:id="lblGenre" />
         <Label fx:id="lblDuration" />
         <Label fx:id="lblYear" />
         <Label fx:id="lblBitrate" />
         <Label fx:id="lblSampleRate" />
         <Label fx:id="lblFilePath" />
         <padding>
            <Insets top="5.0" />
         </padding>
      </VBox>
   </VBox>
</AnchorPane>
